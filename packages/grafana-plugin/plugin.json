{
  "type": "datasource",
  "name": "Causality Analyzer",
  "id": "agentix-causality-analyzer",
  "info": {
    "description": "Causal discovery and RCA data source for Grafana",
    "author": { "name": "AgentiX-E" },
    "version": "1.0.0",
    "logos": { "small": "img/logo.svg", "large": "img/logo.svg" }
  },
  "metrics": true,
  "annotations": true,
  "alerting": false,
  "queryOptions": {
    "maxDataPoints": true,
    "minInterval": true
  },
  "routes": [
    { "path": "discover", "method": "POST", "url": "{{.JsonData.engineUrl}}/discover" },
    { "path": "analyze", "method": "POST", "url": "{{.JsonData.engineUrl}}/analyze" },
    { "path": "detect", "method": "POST", "url": "{{.JsonData.engineUrl}}/detect" },
    { "path": "health", "method": "GET", "url": "{{.JsonData.engineUrl}}/health" }
  ]
}
