# Causality Analyzer Environment Configuration
# Copy this file to .env and fill in your values.
# WARNING: .env is git-ignored — never commit real credentials!

# Docker Compose
PORT=3000
POSTGRES_USER=causality
POSTGRES_PASSWORD=changeme
POSTGRES_DB=causality_analyzer
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_AUTH=neo4j/changeme

# LLM Explainer (optional — falls back to template explanations if not set)
DEEPSEEK_API_KEY=
